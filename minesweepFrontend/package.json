{
  "name": "minesweepfrontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "electron .",
    "build": "tsc -b && vite build",
    "pack:win": "electron-builder --win portable --config.win.signAndEditExecutable=false",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.magichear.minesweep.assist",
    "productName": "MinesweepAssist",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "../dist",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/_bundle/backend",
        "to": "backend"
      },
      {
        "from": "../dist/_bundle/runtime",
        "to": "runtime"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false,
      "artifactName": "MinesweepAssist.exe"
    }
  }
}
